<%- include('partials/head', { title: `Registro #${record.id}` }) %><%- include('partials/header', { admin: true }) %>
<main class="admin-shell narrow"><a class="back" href="/admin">← Voltar aos registros</a>
  <div class="record-heading"><div><span class="eyebrow">Registro #<%= record.id %></span><h1><%= record.type %></h1><p>Recebido em <%= new Date(record.created_at + 'Z').toLocaleString('pt-BR') %></p></div><div class="record-badges"><span class="priority priority-<%= record.priority.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase() %>"><%= record.priority %></span><span class="status"><%= record.status %></span></div></div>
  <% if (saved) { %><div class="alert success">Alterações salvas com sucesso.</div><% } %>
  <div class="record-grid"><section class="panel details"><h2>Manifestação</h2><dl><div><dt>Colaborador</dt><dd><%= record.employee_name %></dd></div><div><dt>Setor</dt><dd><%= record.department %></dd></div><div><dt>Cargo</dt><dd><%= record.job_title || 'Não informado' %></dd></div><div><dt>Prazo</dt><dd><%= record.due_date ? new Date(record.due_date + 'T12:00:00').toLocaleDateString('pt-BR') : 'Não definido' %></dd></div></dl><h3>Descrição</h3><p class="description"><%= record.description %></p>
    <% if (attachments.length) { %><h3>Imagens anexadas</h3><div class="attachment-grid"><% attachments.forEach(image => { %><a href="/admin/anexo/<%= image.id %>" target="_blank"><img src="/admin/anexo/<%= image.id %>" alt="Imagem anexada ao registro"></a><% }) %></div><% } %>
    <% if (history.length) { %><h3>Histórico de alterações</h3><div class="history-list"><% history.forEach(item => { %><article><span></span><div><b><%= item.action %></b><p><%= item.details || 'Sem detalhes adicionais.' %></p><small><%= item.username %> · <%= new Date(item.created_at + 'Z').toLocaleString('pt-BR') %></small></div></article><% }) %></div><% } %>
  </section>
  <section class="panel management"><h2>Acompanhamento da CIPA</h2><form method="post" action="/admin/registro/<%= record.id %>">
    <div class="management-row"><label>Status<select name="status"><% statuses.forEach(x => { %><option <%= record.status === x ? 'selected' : '' %>><%= x %></option><% }) %></select></label><label>Prioridade<select name="priority"><% priorities.forEach(x => { %><option <%= record.priority === x ? 'selected' : '' %>><%= x %></option><% }) %></select></label></div>
    <label>Prazo para tratativa<input type="date" name="due_date" value="<%= record.due_date || '' %>"></label><label>Responsável<input name="assigned_to" maxlength="150" value="<%= record.assigned_to %>" placeholder="Nome do responsável"></label><label>Observações internas<textarea name="internal_notes" maxlength="5000" rows="6" placeholder="Discussões e ações em andamento"><%= record.internal_notes %></textarea></label><label>Solução adotada<textarea name="resolution" maxlength="5000" rows="5" placeholder="Registre a solução definida ou executada"><%= record.resolution || '' %></textarea></label><button class="primary">Salvar alterações</button></form>
    <div class="danger-zone"><form method="post" action="/admin/registro/<%= record.id %>/arquivar"><button class="button secondary">Arquivar</button></form><form method="post" action="/admin/registro/<%= record.id %>/excluir" onsubmit="return confirm('Excluir permanentemente este registro?')"><button class="button danger">Excluir</button></form></div>
  </section></div>
</main></body></html>
